<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Compose owns all UI styling; this theme only removes the action bar and paints the
         window black so there is no white flash before Compose draws. -->
    <style name="Theme.TVLauncher" parent="@android:style/Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/launcher_background</item>
        <item name="android:statusBarColor">@color/launcher_background</item>
        <item name="android:navigationBarColor">@color/launcher_background</item>
    </style>
</resources>
